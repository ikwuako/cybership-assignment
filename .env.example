# Environment Variables for Cybership Carrier Integration Service
# Copy this file to .env and fill in the values.
# Never commit your actual .env file.

# ─── UPS API Credentials ─────────────────────────────────────────────────────
# Obtain from: https://developer.ups.com/apps
UPS_CLIENT_ID=your_ups_client_id_here
UPS_CLIENT_SECRET=your_ups_client_secret_here

# Optional: UPS 6-digit shipper account number.
# Required for negotiated rates; anonymous rate requests work without it.
# UPS_SHIPPER_NUMBER=123456

# ─── UPS API Endpoint ─────────────────────────────────────────────────────────
# Production:  https://onlinetools.ups.com
# CIE/Sandbox: https://wwwcie.ups.com (default for non-production environments)
# UPS_BASE_URL=https://wwwcie.ups.com

# ─── HTTP Client ─────────────────────────────────────────────────────────────
# Request timeout in milliseconds. Default: 10000 (10 seconds)
# UPS_TIMEOUT_MS=10000

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Options: development | test | production
NODE_ENV=development
